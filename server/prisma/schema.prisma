// SMART ECCD – Prisma Schema
// PostgreSQL database for Child Care Center Management Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  CENTER_MANAGER
  TEACHER
  PARENT
}

enum BloomLevel {
  REMEMBER
  UNDERSTAND
  APPLY
  ANALYZE
  EVALUATE
  CREATE
}

enum ActivityStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AssignmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum CompletionStatus {
  COMPLETED
  PARTIAL
  NOT_ATTEMPTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum NotificationType {
  ACTIVITY_ASSIGNED
  PERFORMANCE_RECORDED
  ATTENDANCE_MARKED
  MESSAGE_RECEIVED
  ANNOUNCEMENT
  FLAG_RAISED
  REPORT_READY
  FEE_REMINDER
  LEAVE_APPROVED
  LEAVE_REJECTED
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum FeeStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
  WAIVED
}

enum FeeFrequency {
  MONTHLY
  QUARTERLY
  ANNUAL
  ONE_TIME
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EventType {
  HOLIDAY
  EXAM
  FUNCTION
  MEETING
  ACTIVITY
  OTHER
}

// ─────────────────────────────────────────────────────────────
// CORE MODELS
// ─────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  centerId     String?
  avatar       String?
  phone        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  center            Center?          @relation("CenterUsers", fields: [centerId], references: [id])
  managedCenter     Center?          @relation("CenterManager")
  teacherClasses    Class[]          @relation("ClassTeacher")
  childParents      ChildParent[]
  sentMessages      Message[]        @relation("MessageSender")
  receivedMessages  Message[]        @relation("MessageReceiver")
  notifications     Notification[]
  refreshTokens     RefreshToken[]
  createdActivities Activity[]       @relation("ActivityCreator")
  leaveRequests     LeaveRequest[]   @relation("LeaveRequester")
  leaveReviews      LeaveRequest[]   @relation("LeaveReviewer")
  assignedActivities ActivityAssignment[] @relation("AssignmentTeacher")

  @@index([email])
  @@index([centerId])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model Center {
  id          String   @id @default(cuid())
  name        String
  address     String
  phone       String?
  email       String?
  website     String?
  logo        String?
  theme       String?  @default("default")   // default | ocean | forest | sunset | rose
  themeColor  String?  @default("#4F46E5")   // primary hex colour
  latitude    Float?
  longitude   Float?
  managerId   String   @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  manager        User            @relation("CenterManager", fields: [managerId], references: [id])
  users          User[]          @relation("CenterUsers")
  classes        Class[]
  classrooms     Classroom[]
  activities     Activity[]
  children       Child[]
  academicEvents AcademicEvent[]
  feeStructures  FeeStructure[]
  feeRecords     FeeRecord[]

  @@index([managerId])
}

model Classroom {
  id        String   @id @default(cuid())
  name      String
  centerId  String
  capacity  Int?
  floor     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  center  Center  @relation(fields: [centerId], references: [id])
  classes Class[]

  @@index([centerId])
}

model Class {
  id          String   @id @default(cuid())
  name        String
  ageGroup    String
  centerId    String
  teacherId   String
  classroomId String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  center      Center               @relation(fields: [centerId], references: [id])
  teacher     User                 @relation("ClassTeacher", fields: [teacherId], references: [id])
  classroom   Classroom?           @relation(fields: [classroomId], references: [id])
  children    Child[]
  assignments ActivityAssignment[]

  @@index([centerId])
  @@index([teacherId])
}

model Child {
  id              String   @id @default(cuid())
  studentId       String   @unique  // used for parent self-registration
  firstName       String
  lastName        String
  dateOfBirth     DateTime
  photo           String?
  classId         String
  centerId        String
  medicalNotesEnc String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  class        Class             @relation(fields: [classId], references: [id])
  center       Center            @relation(fields: [centerId], references: [id])
  parents      ChildParent[]
  performance  ChildPerformance[]
  attendance   Attendance[]
  feeRecords   FeeRecord[]
  leaveRequests LeaveRequest[]

  @@index([classId])
  @@index([centerId])
  @@index([studentId])
}

model ChildParent {
  childId   String
  parentId  String
  isPrimary Boolean @default(false)

  child  Child @relation(fields: [childId], references: [id], onDelete: Cascade)
  parent User  @relation(fields: [parentId], references: [id])

  @@id([childId, parentId])
}

// ─────────────────────────────────────────────────────────────
// ACTIVITY MODELS
// ─────────────────────────────────────────────────────────────

model Activity {
  id            String         @id @default(cuid())
  title         String
  description   String
  instructions  String
  bloomLevels   BloomLevel[]
  activityType  String
  ageGroup      String
  durationMins  Int
  resources     String[]
  learningGoals String[]
  status        ActivityStatus @default(DRAFT)
  centerId      String
  createdById   String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  center      Center               @relation(fields: [centerId], references: [id])
  createdBy   User                 @relation("ActivityCreator", fields: [createdById], references: [id])
  assignments ActivityAssignment[]

  @@index([centerId])
  @@index([status])
}

model ActivityAssignment {
  id            String           @id @default(cuid())
  activityId    String
  classId       String
  teacherId     String
  scheduledDate DateTime
  scheduledTime String
  isRecurring   Boolean          @default(false)
  recurringRule String?
  status        AssignmentStatus @default(PENDING)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  activity Activity        @relation(fields: [activityId], references: [id])
  class    Class           @relation(fields: [classId], references: [id])
  teacher  User            @relation("AssignmentTeacher", fields: [teacherId], references: [id])
  record   ActivityRecord?

  @@index([activityId])
  @@index([classId])
  @@index([teacherId])
  @@index([scheduledDate])
}

model ActivityRecord {
  id            String   @id @default(cuid())
  assignmentId  String   @unique
  conductedDate DateTime
  notes         String?
  createdAt     DateTime @default(now())

  assignment   ActivityAssignment @relation(fields: [assignmentId], references: [id])
  performances ChildPerformance[]
  attendances  Attendance[]
}

// ─────────────────────────────────────────────────────────────
// PERFORMANCE & ATTENDANCE
// ─────────────────────────────────────────────────────────────

model ChildPerformance {
  id                 String           @id @default(cuid())
  recordId           String
  childId            String
  completionStatus   CompletionStatus
  bloomLevelAchieved BloomLevel
  skillRatings       Json
  observationNotes   String?
  evidenceUrls       String[]
  isFlagged          Boolean          @default(false)
  flagReason         String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  record ActivityRecord @relation(fields: [recordId], references: [id])
  child  Child         @relation(fields: [childId], references: [id])

  @@index([childId])
  @@index([recordId])
  @@index([bloomLevelAchieved])
}

model Attendance {
  id        String           @id @default(cuid())
  childId   String
  recordId  String?
  date      DateTime
  status    AttendanceStatus
  note      String?
  createdAt DateTime         @default(now())

  child  Child          @relation(fields: [childId], references: [id])
  record ActivityRecord? @relation(fields: [recordId], references: [id])

  @@unique([childId, date])
  @@index([childId])
  @@index([date])
}

// ─────────────────────────────────────────────────────────────
// ACADEMIC CALENDAR
// ─────────────────────────────────────────────────────────────

model AcademicEvent {
  id          String    @id @default(cuid())
  centerId    String
  title       String
  description String?
  eventType   EventType @default(OTHER)
  startDate   DateTime
  endDate     DateTime
  isPublic    Boolean   @default(true)
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  center Center @relation(fields: [centerId], references: [id])

  @@index([centerId])
  @@index([startDate])
}

// ─────────────────────────────────────────────────────────────
// FEE MANAGEMENT
// ─────────────────────────────────────────────────────────────

model FeeStructure {
  id          String       @id @default(cuid())
  centerId    String
  name        String
  description String?
  amount      Decimal      @db.Decimal(10, 2)
  frequency   FeeFrequency @default(MONTHLY)
  dueDay      Int?         // day of month (1-31)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  center     Center      @relation(fields: [centerId], references: [id])
  feeRecords FeeRecord[]

  @@index([centerId])
}

model FeeRecord {
  id             String    @id @default(cuid())
  childId        String
  feeStructureId String
  centerId       String
  amount         Decimal   @db.Decimal(10, 2)
  dueDate        DateTime
  paidDate       DateTime?
  paidAmount     Decimal?  @db.Decimal(10, 2)
  status         FeeStatus @default(PENDING)
  receiptNote    String?
  createdBy      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  child        Child        @relation(fields: [childId], references: [id])
  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])
  center       Center       @relation(fields: [centerId], references: [id])

  @@index([childId])
  @@index([centerId])
  @@index([status])
  @@index([dueDate])
}

// ─────────────────────────────────────────────────────────────
// LEAVE REQUESTS
// ─────────────────────────────────────────────────────────────

model LeaveRequest {
  id          String      @id @default(cuid())
  childId     String
  requestedBy String
  startDate   DateTime
  endDate     DateTime
  reason      String
  status      LeaveStatus @default(PENDING)
  reviewedBy  String?
  reviewNote  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  child    Child  @relation(fields: [childId], references: [id])
  parent   User   @relation("LeaveRequester", fields: [requestedBy], references: [id])
  reviewer User?  @relation("LeaveReviewer", fields: [reviewedBy], references: [id])

  @@index([childId])
  @@index([requestedBy])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// MESSAGING & NOTIFICATIONS
// ─────────────────────────────────────────────────────────────

model Message {
  id         String        @id @default(cuid())
  senderId   String
  receiverId String
  subject    String?
  body       String
  status     MessageStatus @default(SENT)
  createdAt  DateTime      @default(now())

  sender   User @relation("MessageSender", fields: [senderId], references: [id])
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id])

  @@index([senderId])
  @@index([receiverId])
}

model Announcement {
  id        String   @id @default(cuid())
  centerId  String
  title     String
  body      String
  createdBy String
  createdAt DateTime @default(now())

  @@index([centerId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}
