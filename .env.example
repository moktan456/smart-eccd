# ─────────────────────────────────────────────────────────────
# SMART ECCD – Environment Variables Template
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# Local Docker (default)
DATABASE_URL="postgresql://smart_eccd:smart_eccd_pass@localhost:5432/smart_eccd"
# Supabase (production)
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

POSTGRES_USER=smart_eccd
POSTGRES_PASSWORD=smart_eccd_pass
POSTGRES_DB=smart_eccd

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_key
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Cloudinary (File Uploads) ─────────────────────────────────
# Get keys from https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# For local dev: leave blank to use local disk storage
# UPLOAD_PROVIDER=local  (or cloudinary)
UPLOAD_PROVIDER=local

# ── Email (Resend.com) ────────────────────────────────────────
# Get key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@smart-eccd.com

# ── Encryption ────────────────────────────────────────────────
# Used to encrypt sensitive fields like medical notes
ENCRYPTION_KEY=change_me_to_32_char_hex_key_here

# ── Feature Flags ─────────────────────────────────────────────
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_REAL_TIME=true
ENABLE_PDF_REPORTS=false
