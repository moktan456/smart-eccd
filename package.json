{
  "name": "smart-eccd",
  "version": "1.0.0",
  "description": "SMART ECCD – Child Care Center Management Platform powered by Bloom's Taxonomy",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=client",
    "seed": "npm run seed --workspace=server",
    "migrate": "npm run migrate --workspace=server",
    "lint": "eslint client/src server/src --ext .js,.jsx"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0"
  }
}
